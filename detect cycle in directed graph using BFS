from collections import deque
class Solution:
    def isCyclic(self, V, edges):
        # code here 
        adj=[]
        for _ in range(V):
            adj.append([])
        for u,v in edges:
            adj[u].append(v)
        inDegree=[0]*v
        for u,v in edges:
            inDegree[v]+=1
        q=deque([])
        for i in range(0,V):
            if(inDegree[i]==0):
                q.append(i)
        ans=[]
        while(len(q)>0):
            node=q.popleft()
            ans.append(node)
            for adjNode in adj[node]:
                inDegre[adjNode]-=1 
                if(inDegree[adjNode] == 0):
                    q.append(adjNode) 
        if(len(ans)!=V):
            return True
        return False
